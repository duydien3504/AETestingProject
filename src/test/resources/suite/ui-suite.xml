<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI Test Suite" parallel="tests" thread-count="3">
    <listeners>
        <listener class-name="listeners.TestListener" />
    </listeners>
    <test name="Web E2E Tests">
        <packages>
            <package name="tests.ui.*" />
        </packages>
    </test>
</suite>
